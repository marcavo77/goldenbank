{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/archive-messages",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/cleanup-all",
      "schedule": "0 3 */3 * *"
    }
  ]
}

